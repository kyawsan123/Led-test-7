#include <xc.h>

// Configuration Bits (LVP နှင့် တခြား မလိုအပ်သော bit များ အားလုံး ပိတ်ထားသည်)
#pragma config FOSC = INTRC_NOCLKOUT // Internal Oscillator
#pragma config WDTE = OFF            // Watchdog Timer OFF
#pragma config PWRTE = OFF           // Power-up Timer OFF
#pragma config MCLRE = ON            // MCLR Pin Enabled (Pin 1 ကို 5V ပေးရမည်)
#pragma config CP = OFF              // Code Protection OFF
#pragma config CPD = OFF             // Data Code Protection OFF
#pragma config BOREN = OFF           // Brown Out Reset OFF
#pragma config IESO = OFF            // Internal External Switchover OFF
#pragma config FCMEN = OFF           // Fail-Safe Clock Monitor OFF
#pragma config LVP = OFF             // Low Voltage Programming OFF (ပြဿနာရှာတတ်သဖြင့် မဖြစ်မနေ ပိတ်ရမည်)

#define _XTAL_FREQ 4000000 // 4MHz

// Buttons Input Mapping
#define BTN_POWER    RA0
#define BTN_DIM      RA1
#define BTN_UP       RA2
#define BTN_DOWN     RA3

// Global Variables
volatile unsigned int timer_minutes = 0;
volatile unsigned int seconds_counter = 0;
unsigned char pwr_status = 0; 
unsigned char dim_level = 0; 

// Common Cathode 7-Segment Codes (0-9)
unsigned char segment_code[] = {0x3F, 0x06, 0x5B, 0x4F, 0x66, 0x6D, 0x7D, 0x07, 0x7F, 0x6F};

void setup(void);
void update_system_outputs(void);
void display_process(void);

// Timer1 Interrupt (100ms interval)
void __interrupt() isr(void) {
    if (TMR1IF) {
        TMR1H = 0x0B; TMR1L = 0xDC; // Reload for 100ms
        
        if (pwr_status && timer_minutes > 0) {
            seconds_counter++;
            if (seconds_counter >= 600) { // 60 seconds (1 minute)
                timer_minutes--;
                seconds_counter = 0;
                if (timer_minutes == 0) {
                    pwr_status = 0; // အချိန်ပြည့်လျှင် အားလုံးပိတ်
                }
            }
        }
        TMR1IF = 0;
    }
}

void main(void) {
    setup();
    
    while(1) {
        // 1. Power On/Off Logic
        if (BTN_POWER == 0) {
            __delay_ms(40);
            if (BTN_POWER == 0) {
                pwr_status = !pwr_status;
                if (pwr_status) {
                    dim_level = 0;       
                    timer_minutes = 0;   // အစပိုင်းတွင် Timer မသုံးသေးပါ (--:-- ပြရန်)
                }
                while(!BTN_POWER) display_process();
            }
        }

        if (pwr_status) {
            // 2. Dimming Logic
            if (BTN_DIM == 0) {
                __delay_ms(40);
                if (BTN_DIM == 0) {
                    dim_level++;
                    if (dim_level > 2) dim_level = 0;
                    while(!BTN_DIM) display_process();
                }
            }

            // 3. Timer Up Button Logic (5 mins step)
            if (BTN_UP == 0) {
                __delay_ms(40);
                if (timer_minutes < 180) timer_minutes += 5;
                seconds_counter = 0;
                while(!BTN_UP) display_process();
            }

            // 4. Timer Down Button Logic (5 mins step)
            if (BTN_DOWN == 0) {
                __delay_ms(40);
                if (timer_minutes >= 5) timer_minutes -= 5;
                while(!BTN_DOWN) display_process();
            }
            
            update_system_outputs(); 
        } else {
            CCPR1L = 0;
            PORTC &= 0x07; // Indicators (RC3, RC4, RC5) အားလုံးပိတ်
        }

        display_process(); 
    }
}

void setup(void) {
    ANSEL = 0; ANSELH = 0; // All Digital I/O
    
    TRISA = 0x0F; // RA0-RA3 Inputs (Buttons), RA4-RA5 Outputs (Digits)
    TRISB = 0x00; // PORTB Outputs (7-Seg Data)
    TRISC = 0x00; // PORTC Outputs
    
    PORTA = 0x00;
    PORTB = 0x00;
    PORTC = 0x00;
    
    // PWM Configuration (CCP1 - RC2 Pin သီးသန့်)
    T2CON = 0x04;  
    PR2 = 255;     
    CCP1CON = 0x0C;
    
    // Timer1 Configuration (100ms)
    T1CON = 0x11;  
    TMR1H = 0x0B;  
    TMR1L = 0xDC;
    TMR1IE = 1; GIE = 1; PEIE = 1;
}

void update_system_outputs(void) {
    PORTC &= 0x07; // RC3, RC4, RC5 များကို အရင်ရှင်းလင်းမည်
    
    if (dim_level == 0) { 
        CCPR1L = 50;        // Low Brightness
        PORTC |= 0x08;      // RC3 = ON
    } else if (dim_level == 1) { 
        CCPR1L = 150;       // Mid Brightness
        PORTC |= 0x10;      // RC4 = ON
    } else { 
        CCPR1L = 255;       // High Brightness
        PORTC |= 0x20;      // RC5 = ON
    }
}

void display_process(void) {
    if (!pwr_status) {
        PORTB = 0x00;
        PORTA &= 0xCF; // RA4, RA5 ပိတ်
        PORTC &= 0xFC; // RC0, RC1 ပိတ်
        return;
    }

    int hrs = timer_minutes / 60;
    int mins = timer_minutes % 60;
    int digits[4] = {hrs/10, hrs%10, mins/10, mins%10};

    for(int i=0; i<4; i++) {
        // Clear previous digit pins to avoid ghosting
        PORTA &= 0xCF; 
        PORTC &= 0xFC; 

        // Load Segment Data
        if (timer_minutes == 0) PORTB = 0x40; // Dash '-'
        else PORTB = segment_code[digits[i]]; 
        
        // Turn ON specific Digit Pin
        if(i == 0)      RC0 = 1; // Digit 1 -> RC0
        else if(i == 1) RC1 = 1; // Digit 2 -> RC1
        else if(i == 2) RA4 = 1; // Digit 3 -> RA4
        else            RA5 = 1; // Digit 4 -> RA5
        
        __delay_ms(1); 
    }
}
